# ─── Shopify Admin API ────────────────────────────────────────────────────────
# Your dev/eval store domain (no https://)
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com

# Admin API access token (needs write_products scope)
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Admin API version (default: 2025-01)
SHOPIFY_API_VERSION=2025-01

# ─── Shopify Catalog MCP ──────────────────────────────────────────────────────
# Endpoint for Global Catalog (keyless access works at low volume)
CATALOG_MCP_URL=https://catalog.shopify.com/api/ucp/mcp

# Optional: Dev Dashboard API key for higher rate limits
# Leave blank to use keyless access
CATALOG_API_KEY=

# ─── Anthropic (mutation engine + prompt generation) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Claude model for mutation proposals and prompt generation
ANTHROPIC_MODEL=claude-opus-4-7

# ─── Experiment settings ──────────────────────────────────────────────────────
# Number of repetitions per eval prompt (K in MRR calculation)
EVAL_K=5

# Minimum hours between cycles (re-index cadence)
CYCLE_MIN_HOURS=24

# Standard deviations above/below baseline required for KEEP/REVERT decision
DECISION_SIGMA=2.0

# ─── Optional: storefront catalog scoping (your specific store's MCP endpoint)
# Leave blank to use Global Catalog
STOREFRONT_MCP_URL=
